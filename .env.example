PORT=3000

# Cadena de conexión a MongoDB Atlas
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/securestock

# Clave secreta para firmar los tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia-esta-clave-por-una-larga-y-aleatoria

# URL pública del frontend, usada para armar el enlace de recuperación de contraseña
FRONTEND_URL=http://localhost:3000

# Configuración SMTP para el envío de correos de recuperación de contraseña
# Si se dejan vacías, el enlace de recuperación se muestra en la consola del servidor
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Datos del administrador inicial, usados por "npm run seed"
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@securestock.com
ADMIN_PASSWORD=cambia-esta-clave
